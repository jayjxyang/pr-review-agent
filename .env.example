GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── GitHub Auth (choose one) ──
# App mode (production) — set all three:
GITHUB_APP_ID=3922011
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_APP_INSTALLATION_ID=136973092
# PAT mode (local dev fallback) — only used if APP_ID is not set:
# GITHUB_APP_TOKEN=ghp_your-token

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/pr_review
REDIS_URL=redis://redis:6379/0

AI_GATEWAY_URL=http://ai-gateway:8080/v1
AI_GATEWAY_KEY=your-gateway-key
SCAN_SCENARIO=code-review-scan
REASON_SCENARIO=code-review-reason

MAX_ROUNDS=15
MAX_INPUT_TOKENS=60000
COMPRESS_AT_ROUND=5
